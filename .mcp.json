{
  "_comment": "Project-scoped MCP config — auto-loaded by Claude Code when launched in this repo. Requires the WEB_MCP_ROOT environment variable to point at the absolute path of your local clone. Example: export WEB_MCP_ROOT=\"$(pwd)\" after cd'ing into the repo.",
  "mcpServers": {
    "browser-mcp": {
      "type": "stdio",
      "command": "${WEB_MCP_ROOT}/.venv/bin/python",
      "args": ["-m", "browser_mcp.server"]
    },
    "burp-mcp": {
      "type": "stdio",
      "command": "${WEB_MCP_ROOT}/.venv/bin/python",
      "args": ["-m", "burp_mcp.server"]
    },
    "parley-mcp": {
      "type": "stdio",
      "command": "${WEB_MCP_ROOT}/.venv/bin/python",
      "args": ["${WEB_MCP_ROOT}/MCPs/parley-mcp/run_server.py"],
      "cwd": "${WEB_MCP_ROOT}/MCPs/parley-mcp"
    },
    "github-mcp": {
      "type": "stdio",
      "command": "${WEB_MCP_ROOT}/.venv/bin/python",
      "args": ["-m", "github_mcp"],
      "cwd": "${WEB_MCP_ROOT}/MCPs/github-mcp/MCPs",
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
